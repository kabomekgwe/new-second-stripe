# ============================================
# Stripe Payment Application - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!
# ============================================

# ============================================
# Stripe Configuration (Required)
# Get these from: https://dashboard.stripe.com/apikeys
# ============================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe metered price ID for monthly management fees. Must be linked to a Billing Meter.
# Create at: Dashboard → Products → Add metered price linked to management_fee meter
STRIPE_BILLING_METERED_PRICE_ID=price_xxx

# ============================================
# Database Configuration (Required)
# ============================================
DB_HOST=localhost
DB_PORT=1521
DB_USER=app_user
DB_PASSWORD=app_password
DB_SERVICE_NAME=FREEPDB1

# ============================================
# Redis Configuration (Required)
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# Session Security (CRITICAL - Change in Production)
# Generate with: openssl rand -hex 32
# ============================================
SESSION_SECRET=change_me_to_random_64_character_string

# ============================================
# Frontend URL (Required for CORS)
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# Email Configuration (Webhooks Backend)
# ============================================
RESEND_API_KEY=resend_api_key_here
RESEND_FROM_EMAIL=billing@yourdomain.com

# ============================================
# Core Backend Configuration
# ============================================
CORE_BACKEND_PORT=4917

# ============================================
# Webhooks Backend Configuration
# ============================================
WEBHOOKS_BACKEND_PORT=4923

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_PORT=3000
CORE_API_URL=http://localhost:4917
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}

# ============================================
# Stripe Payment Method Mode
# 'auto' = use Stripe's automatic_payment_methods (production)
# 'explicit' = use country-specific payment_method_types (testing)
# ============================================
STRIPE_PAYMENT_METHOD_MODE=auto

# ============================================
# Environment Mode
# Options: development, production
# ============================================
NODE_ENV=development
